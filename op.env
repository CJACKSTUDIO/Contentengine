# Local dev secret bindings.
# Run the studio with:
#   op run --env-file=op.env -- npm run dev
#
# Each line maps an env var name → 1Password reference. `op` resolves
# them into the child process env, so application code just reads
# `process.env.X`. No secret values live on disk.

OPENAI_API_KEY="op://Catjack-world/OpenAI/credential"
GEMINI_API_KEY="op://Catjack-world/Gemini/credential"
ELEVENLABS_API_KEY="op://Catjack-world/ElevenLabs/credential"
FAL_API_KEY="op://Catjack-world/fal/credential"
LEONARDO_API_KEY="op://Catjack-world/Leonardo/credential"
POSTIZ_API_KEY="op://Catjack-world/Postiz/credential"

# Anthropic added in Block 8.
ANTHROPIC_API_KEY="op://Catjack-world/Anthropic/credential"

# Supabase
SUPABASE_URL="op://Catjack-world/Supabase/url"
SUPABASE_ANON_KEY="op://Catjack-world/Supabase/anon_key"
SUPABASE_SERVICE_ROLE_KEY="op://Catjack-world/Supabase/service_role_key"

# Cloudinary
CLOUDINARY_CLOUD_NAME="op://Catjack-world/Cloudinary/cloud_name"
CLOUDINARY_API_KEY="op://Catjack-world/Cloudinary/api_key"
CLOUDINARY_API_SECRET="op://Catjack-world/Cloudinary/api_secret"

# YouTube
YOUTUBE_REFRESH_TOKEN="op://Catjack-world/YouTube/refresh_token"
YOUTUBE_CLIENT_ID="op://Catjack-world/YouTube/client_id"
YOUTUBE_CLIENT_SECRET="op://Catjack-world/YouTube/client_secret"
YOUTUBE_CHANNEL_ID="op://Catjack-world/YouTube/channel_id"

# Inngest — added in Block 7
INNGEST_EVENT_KEY="op://Catjack-world/Inngest/event_key"
INNGEST_SIGNING_KEY="op://Catjack-world/Inngest/signing_key"

# Railway worker — added in Block 3
RAILWAY_WORKER_URL="op://Catjack-world/RailwayWorker/url"
RAILWAY_WORKER_TOKEN="op://Catjack-world/RailwayWorker/token"
